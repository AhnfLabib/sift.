NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co  # Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                        # Supabase anon/public API key
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server-only: webhook + cron
ALLOWED_EMAIL=you@example.com             # the single permitted login
CRON_SECRET=generate-a-long-random-string # shared secret to authenticate Vercel cron requests
RESEND_API_KEY=re_...                     # Resend API key for sending reminder emails
REMINDER_FROM_EMAIL=sift@yourdomain.com   # From address used for reminder emails
REMINDER_TO_EMAIL=you@example.com         # Destination address for reminder emails
TWILIO_ACCOUNT_SID=AC...                  # Twilio account SID for WhatsApp reminders
TWILIO_AUTH_TOKEN=...                     # Twilio auth token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # sandbox number
GOOGLE_SERVICE_ACCOUNT_EMAIL=sift@project.iam.gserviceaccount.com  # Google service account email for Sheets export
GOOGLE_SERVICE_ACCOUNT_KEY=-----BEGIN PRIVATE KEY-----\n...   # \n-escaped
GOOGLE_SHEETS_SPREADSHEET_ID=1AbC...      # target spreadsheet ID for exports
